rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Gedeelde Collecties ---
    // Gebruikers en hun rollen zijn gedeeld. Pad is /future-factory/users/
    match /future-factory/users/{userId} {
      // Alleen de gebruiker zelf of een admin mag eigen data aanpassen.
      allow read, write: if request.auth != null && (request.auth.uid == userId ||
        get(/databases/$(database)/documents/future-factory/users/$(request.auth.uid)).data.role == 'admin');
    }

    // --- Productie Omgeving (Live Pilot) ---
    // Strikte regels voor de live fabriek data onder /future-factory/production
    match /future-factory/production/{document=**} {
      // Ingelogde gebruikers mogen productiedata lezen en schrijven.
      // Dit kan verder worden aangescherpt per rol.
      allow read: if request.auth != null;
    }

    // Specifieke, strengere regel voor productie-berichten
    match /future-factory/production/messages/{messageId} {
      allow create: if request.auth != null; // Iedereen mag berichten maken
      allow read, update: if request.auth != null && (
            resource.data.senderId == request.auth.uid ||
            resource.data.to == request.auth.token.email ||
            get(/databases/$(database)/documents/future-factory/users/$(request.auth.uid)).data.role == 'admin'
          );
    }
    
    // --- Preview/Test Omgeving ---
    // Flexibele regels voor de testomgeving onder /artifacts/{appId}
    match /artifacts/{appId}/{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}