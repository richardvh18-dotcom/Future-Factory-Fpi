  "name": "fpi-future-factory",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "@vitejs/plugin-react": "^4.3.3",
    "chart.js": "^4.4.1",
    "date-fns": "^2.30.0",
    "firebase": "^10.7.1",
    "framer-motion": "^10.18.0",
    "gantt-task-react": "^0.3.9",
    "i18next": "^23.7.11",
    "i18next-browser-languagedetector": "^7.2.0",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^3.8.4",
    "lucide-react": "^0.309.0",
    "pdfjs-dist": "^4.10.38",
    "react": "^18.2.0",
    "react-beautiful-dnd": "^13.1.1",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "react-i18next": "^14.0.0",
    "react-qr-code": "^2.0.12",
    "react-router-dom": "^6.21.1",
    "react-window": "^2.2.7",
    "terser": "^5.36.0",
    "vercel": "^50.23.2",
    "web-vitals": "^2.1.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/parser": "^8.56.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^10.0.2",
    "eslint-plugin-i18next": "^6.1.3",
    "husky": "^8.0.0",
    "lint-staged": "^16.2.7",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vite": "^7.3.1"
  },
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "build": "NODE_OPTIONS=--max-old-space-size=4096 vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .js,.jsx",
    "lint:strict": "eslint src --ext .js,.jsx --max-warnings=0",
    "prepare": "husky install",
    "prevalidate": "node scripts/cleanup-duplicates.js",
    "validate": "npm run lint && npm run type-check && npm run build",
    "validate:strict": "npm run lint:strict && npm run type-check && npm run build",
    "type-check": "tsc --noEmit",
    "find-bugs": "find src -name '\\*,jsx'"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx}": "eslint --fix"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
