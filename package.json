{
  "name": "fpi-future-factory",
  "version": "0.1.83",
  "private": true,
  "type": "module",
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "@vitejs/plugin-react": "^4.3.3",
    "chart.js": "^4.4.1",
    "date-fns": "^2.30.0",
    "firebase": "^10.7.1",
    "framer-motion": "^10.18.0",
    "gantt-task-react": "^0.3.9",
    "html2canvas": "^1.4.1",
    "i18next": "^23.7.11",
    "i18next-browser-languagedetector": "^7.2.0",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^3.8.4",
    "lucide-react": "^0.309.0",
    "papaparse": "^5.5.3",
    "pdfjs-dist": "^4.10.38",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "react-i18next": "^14.0.0",
    "react-qr-code": "^2.0.12",
    "react-router-dom": "^6.21.1",
    "react-window": "^2.2.7",
    "terser": "^5.36.0",
    "web-vitals": "^2.1.4",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@firebase/rules-unit-testing": "^3.0.4",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.8.0",
    "@types/qrcode": "^1.5.6",
    "@types/w3c-web-usb": "^1.0.14",
    "@typescript-eslint/parser": "^8.56.0",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^10.0.2",
    "eslint-plugin-i18next": "^6.1.3",
    "firebase-admin": "^13.7.0",
    "firebase-tools": "^15.22.0",
    "husky": "^8.0.0",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.2.7",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vite": "^5.4.21",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^3.2.4"
  },
  "scripts": {
    "dev": "vite",
    "dev:test": "vite --mode development",
    "dev:prod": "vite --mode production",
    "start": "vite",
    "build": "vite build",
    "build:test": "vite build --mode development",
    "build:prod": "vite build --mode production",
    "version:bump:patch": "node scripts/bump-version.cjs",
    "version:bump:patch:dry": "node scripts/bump-version.cjs --dry-run",
    "deploy": "npm run version:bump:patch && npm run build && npx -p firebase-tools firebase deploy --only hosting",
    "deploy:test": "firebase use staging && npm run build:test && firebase deploy --only hosting",
    "deploy:prod": "firebase use default && npm run build:prod && firebase deploy --only hosting",
    "preview": "vite preview",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx",
    "lint:strict": "eslint src --ext .js,.jsx,.ts,.tsx --max-warnings=0",
    "enforce:new-ts": "node scripts/enforce-new-typescript.cjs",
    "ts:refresh-baseline": "node scripts/refresh-ts-js-baseline.cjs",
    "prepare": "husky install",
    "prevalidate": "node scripts/cleanup-duplicates.js",
    "repair:lossen": "node scripts/repair-lossen-routing.cjs",
    "migrate:legacy-logs": "node scripts/migrate-legacy-activity-logs-via-cli-auth.cjs",
    "migrate:legacy-logs:apply": "node scripts/migrate-legacy-activity-logs-via-cli-auth.cjs --apply",
    "promote:prod": "bash scripts/promote-to-production.sh",
    "import:planning:auto": "node scripts/auto-planning-import.cjs --watch --dir ./imports/planning",
    "import:planning:once": "node scripts/auto-planning-import.cjs --dir ./imports/planning",
    "validate": "npm run enforce:new-ts && npm run lint && npm run type-check && npm run build",
    "validate:strict": "npm run enforce:new-ts && npm run lint:strict && npm run type-check && npm run build",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rules": "firebase emulators:exec \"vitest run tests/firestore\" --only firestore",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:regression:bh18": "node --test scripts/regression/bh18-filter.test.mjs",
    "validate:ai-planning": "node scripts/validate-ai-planning-context.cjs",
    "find-bugs": "find src -name '\\*,jsx'"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx}": "eslint --fix"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
